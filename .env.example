# Logging
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs      # directory for app.log

# Device: cpu → (device=cpu, compute_type=int8)
#         gpu → (device=cuda, compute_type=float16)
DEVICE=gpu

# Whisper model — overrides config.toml value (tiny | base | small | medium | large-v3)
WHISPER_MODEL_SIZE=large-v3

# MinIO credentials
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# LM Studio - override config.toml values if set
LM_STUDIO_BASE_URL=http://192.168.1.100:1234/v1
LM_STUDIO_API_KEY=your-lm-studio-api-token
